{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "node scripts/check-npm-registry.mjs && npm ci --include=dev --registry=https://registry.npmjs.org/",
  "buildCommand": "npm run build:vercel",
  "outputDirectory": "dist",
  "functions": {
    "api/index.ts": {
      "maxDuration": 300,
      "includeFiles": "vercel-runtime/**",
      "excludeFiles": "node_modules/**"
    }
  },
  "headers": [
    {
      "source": "/pdf.worker.mjs",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/javascript; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/pdf.worker.min.mjs",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/javascript; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin-allow-popups"
        },
        {
          "key": "Cross-Origin-Embedder-Policy",
          "value": "unsafe-none"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/__/firebase/:path*",
      "destination": "https://al-ai-chat.firebaseapp.com/__/firebase/:path*"
    },
    {
      "source": "/__/auth/:path*",
      "destination": "https://al-ai-chat.firebaseapp.com/__/auth/:path*"
    },
    {
      "source": "/api/:path*",
      "destination": "/api?__path=:path*"
    },
    {
      "source": "/manifest.json",
      "destination": "/manifest.webmanifest"
    },
    {
      "source": "/clora-x/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
