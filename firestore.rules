rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Catch-all safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Standard security helpers
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && (
        request.auth.uid == userId ||
        (request.auth.token != null && request.auth.token.email != null && request.auth.token.email == userId)
      );
    }

    function isContentManager() {
      return signedIn() && (
        request.auth.token.admin == true ||
        request.auth.token.role in ["admin", "ops", "content_editor", "teacher"] ||
        (request.auth.token.roles != null && (
          "admin" in request.auth.token.roles ||
          "ops" in request.auth.token.roles ||
          "content_editor" in request.auth.token.roles ||
          "teacher" in request.auth.token.roles
        ))
      );
    }

    function isReviewer() {
      return signedIn() && (
        request.auth.token.admin == true ||
        request.auth.token.role in ["admin", "ops", "reviewer"] ||
        (request.auth.token.roles != null && (
          "admin" in request.auth.token.roles ||
          "ops" in request.auth.token.roles ||
          "reviewer" in request.auth.token.roles
        ))
      );
    }

    function isAdmin() {
      return isContentManager();
    }

    function isPersonalScope(data) {
      return data.visibility == "private"
        && data.sourceScope in ["personal", "chat_upload", "images"];
    }

    // Users collection and sub-collections
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();

      match /notifications/{docId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /profile/{docId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // User Roles collection
    match /user_roles/{userId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    // RAG sources and chunks
    match /rag_sources/{id} {
      allow read: if signedIn() && (
        resource.data.visibility in ["official", "shared", "class", "institution", "public"] ||
        resource.data.ownerUid == request.auth.uid ||
        isAdmin()
      );
      allow create: if signedIn()
        && request.resource.data.ownerUid == request.auth.uid
        && (isPersonalScope(request.resource.data) || isContentManager());
      allow update: if signedIn() && (
        isContentManager() || (
          resource.data.ownerUid == request.auth.uid
          && isPersonalScope(resource.data)
          && isPersonalScope(request.resource.data)
        )
      );
      allow delete: if signedIn() && (
        isContentManager() || (resource.data.ownerUid == request.auth.uid && isPersonalScope(resource.data))
      );
    }

    match /rag_chunks/{id} {
      allow read: if signedIn() && (
        resource.data.visibility in ["official", "shared", "class", "institution", "public"] ||
        resource.data.ownerUid == request.auth.uid ||
        isAdmin()
      );
      allow create: if signedIn()
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.visibility == "private";
      allow update, delete: if isContentManager();
    }

    // Past papers
    match /past_papers/{id} {
      allow read: if signedIn();
      allow create, update, delete: if isContentManager();
    }


    match /lesson_resources/{id} {
      allow read: if signedIn() && (
        resource.data.ownerUid == request.auth.uid ||
        (resource.data.published == true && resource.data.visibility in ["official", "shared", "class", "institution", "public"]) ||
        isContentManager()
      );
      allow create, update, delete: if isContentManager();
    }

    // Knowledge base
    match /knowledge_sources/{id} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /knowledge_chunks/{id} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    // Indexes and metadata
    match /exam_question_index/{id} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /syllabus_nodes/{id} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /exam_pattern_reports/{id} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /prediction_reports/{id} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    // PDF caching
    match /pdf_question_cache/{id} {
      allow read: if signedIn();
      allow create, update, delete: if isContentManager() || isReviewer();
    }

    // Verified answers
    match /verified_answers/{id} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    // Audit events (Immutable: write-once, never delete or update)
    match /audit_events/{id} {
      allow read: if isAdmin();
      allow create: if signedIn();
      allow update, delete: if false;
    }

    // Canonical Source Registry. Video writes are server-only.
    match /sources/{id} {
      allow read: if signedIn() && (
        resource.data.ownerUid == request.auth.uid ||
        resource.data.visibility in ["official", "shared", "class", "institution", "public"] ||
        isAdmin()
      );
      allow create: if signedIn()
        && request.resource.data.ownerUid == request.auth.uid
        && (isPersonalScope(request.resource.data) || isContentManager());
      allow update, delete: if isContentManager();
    }

    match /videos/{id} {
      allow read: if signedIn() && (
        isAdmin() || (
          resource.data.isPublished == true &&
          resource.data.allowPlayback == true &&
          resource.data.status == "ready" &&
          resource.data.visibility in ["class", "institution", "public"]
        )
      );
      allow write: if false;
    }

    match /videoPlaybackSessions/{id} {
      allow read, write: if false;
    }

    match /videoAuditLogs/{id} {
      allow read, write: if false;
    }
  }
}
