rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null && request.auth.token.firebase.sign_in_provider != "anonymous";
    }

    function hasRole(role) {
      return signedIn() && (
        request.auth.token.role == role ||
        (request.auth.token.roles != null && role in request.auth.token.roles)
      );
    }

    function isAdmin() {
      return signedIn() && (request.auth.token.admin == true || hasRole("admin"));
    }

    function isOps() {
      return hasRole("ops");
    }

    function canManageContent() {
      return isAdmin() || isOps() || hasRole("content_editor") || hasRole("teacher");
    }

    function isReviewer() {
      return isAdmin() || isOps() || hasRole("reviewer");
    }

    function isOwnerUid(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isPersonalSource(data) {
      return data.ownerUid == request.auth.uid
        && data.visibility == "private"
        && data.published == false
        && data.sourceScope in ["personal", "chat_upload", "images"];
    }

    function hasClassAudience(data) {
      return data.visibility == "class"
        && data.classId != null
        && request.auth.token.classIds != null
        && data.classId in request.auth.token.classIds;
    }

    function hasInstitutionAudience(data) {
      return data.visibility == "institution"
        && data.institutionId != null
        && request.auth.token.institutionIds != null
        && data.institutionId in request.auth.token.institutionIds;
    }

    function isPublishedForUser(data) {
      return data.published == true && (
        data.visibility in ["public", "official", "shared"] ||
        hasClassAudience(data) ||
        hasInstitutionAudience(data)
      );
    }

    function canReadSource(data) {
      return signedIn() && (
        data.ownerUid == request.auth.uid ||
        isPublishedForUser(data) ||
        canManageContent() ||
        isReviewer()
      );
    }

    // Private user records are owner-only. Only true administrators and ops can
    // perform support access; teachers/content editors never inherit user-data access.
    match /users/{uid} {
      allow read, write: if isOwnerUid(uid) || isAdmin() || isOps();

      match /{subPath=**} {
        allow read, write: if isOwnerUid(uid) || isAdmin() || isOps();
      }
    }

    match /user_roles/{uid} {
      allow get: if isOwnerUid(uid) || isAdmin() || isOps();
      allow list: if isAdmin() || isOps();
      allow create, update, delete: if isAdmin();
    }

    match /rag_sources/{id} {
      allow read: if canReadSource(resource.data);
      allow create: if signedIn() && (
        isPersonalSource(request.resource.data) || canManageContent()
      );
      allow update: if canManageContent() || (
        isPersonalSource(resource.data) &&
        isPersonalSource(request.resource.data) &&
        request.resource.data.ownerUid == resource.data.ownerUid &&
        request.resource.data.sourceScope == resource.data.sourceScope &&
        request.resource.data.visibility == resource.data.visibility &&
        request.resource.data.published == resource.data.published
      );
      allow delete: if canManageContent() || isPersonalSource(resource.data);
    }

    match /rag_chunks/{id} {
      allow read: if canReadSource(resource.data);
      allow create: if signedIn() && (
        isPersonalSource(request.resource.data) || canManageContent()
      );
      allow update, delete: if canManageContent() || (
        resource.data.ownerUid == request.auth.uid &&
        resource.data.visibility == "private" &&
        request.resource.data.ownerUid == resource.data.ownerUid &&
        request.resource.data.visibility == "private"
      );
    }

    match /past_papers/{id} {
      allow read: if signedIn() && (
        isPublishedForUser(resource.data) || canManageContent() || isReviewer()
      );
      allow create, update, delete: if canManageContent();
    }

    match /lesson_resources/{id} {
      allow read: if canReadSource(resource.data);
      allow create, update, delete: if canManageContent();
    }

    match /knowledge_sources/{id} {
      allow read: if canReadSource(resource.data);
      allow create, update, delete: if canManageContent();
    }

    match /knowledge_chunks/{id} {
      allow read: if canReadSource(resource.data);
      allow create, update, delete: if canManageContent();
    }

    match /sources/{id} {
      allow read: if canReadSource(resource.data);
      allow create: if signedIn() && (
        isPersonalSource(request.resource.data) || canManageContent()
      );
      allow update: if canManageContent() || (
        isPersonalSource(resource.data) &&
        isPersonalSource(request.resource.data) &&
        request.resource.data.ownerUid == resource.data.ownerUid &&
        request.resource.data.sourceScope == resource.data.sourceScope &&
        request.resource.data.visibility == "private" &&
        request.resource.data.published == false
      );
      allow delete: if canManageContent() || isPersonalSource(resource.data);
    }

    match /videos/{id} {
      allow read: if signedIn() && (
        canManageContent() || (
          resource.data.status == "ready" &&
          resource.data.isPublished == true &&
          resource.data.allowPlayback == true &&
          (
            resource.data.visibility in ["public", "shared"] ||
            hasClassAudience(resource.data) ||
            hasInstitutionAudience(resource.data)
          )
        )
      );
      allow write: if false;
    }

    // These are exposed only through authenticated server endpoints. This
    // prevents clients from enumerating private answers, OCR text, or audit data.
    match /pdf_question_cache/{id} { allow read, write: if false; }
    match /verified_answers/{id} { allow read, write: if false; }
    match /audit_events/{id} { allow read, write: if false; }
    match /audit_logs/{id} { allow read, write: if false; }
    match /videoPlaybackSessions/{id} { allow read, write: if false; }
    match /videoAuditLogs/{id} { allow read, write: if false; }

    match /exam_question_index/{id} {
      allow read: if signedIn();
      allow write: if false;
    }
    match /syllabus_nodes/{id} {
      allow read: if signedIn();
      allow write: if false;
    }
    match /exam_pattern_reports/{id} {
      allow read: if signedIn();
      allow write: if false;
    }
    match /prediction_reports/{id} {
      allow read: if signedIn();
      allow write: if false;
    }
    match /learning_signal_aggregates/{id} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
