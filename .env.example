# Deploy Target: aistudio_applet (default) or cloud_run
APP_DEPLOY_TARGET=aistudio_applet

# Gemini API Configurations
GEMINI_USE_VERTEX=true
GOOGLE_CLOUD_PROJECT=al-ai-chat
GOOGLE_CLOUD_LOCATION=global

# Google Cloud Service Account
GOOGLE_APPLICATION_CREDENTIALS_JSON=
FIRESTORE_DATABASE_ID=
FIREBASE_STORAGE_BUCKET=

# Firebase browser configuration (public identifiers, never service-account secrets)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=al-ai-chat.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=al-ai-chat
VITE_FIREBASE_STORAGE_BUCKET=al-ai-chat.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIRESTORE_DATABASE_ID=
VITE_FIREBASE_APP_CHECK_SITE_KEY=

# Model specific configurations
GEMINI_API_KEY=
GEMINI_DEFAULT_MODEL=gemini-3.5-flash
GEMINI_FAST_MODEL=gemini-3.5-flash
GEMINI_PDF_QA_MODEL=gemini-3.5-flash
GEMINI_FINAL_MODEL=gemini-3.1-pro-preview

# Gemini Live voice
ENABLE_GEMINI_LIVE=false
GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview
ENABLE_REALTIME_VOICE=true

# Feature flags
ENABLE_TTS=false
ENABLE_AUTO_OCR=false
ENABLE_IMAGE_GENERATION=false

# Server
NODE_ENV=development
PORT=3000
VITE_BACKEND_DIRECT_URL=

# CORS / production safety
ALLOWED_ORIGINS=https://tecal.vercel.app
DEV_BYPASS_AUTH=false
ENABLE_MOCK_ROUTES=false
ENABLE_MODEL_TEST_ROUTE=false
MAX_BODY_LIMIT_MB=2

# Secure lesson videos. Keep signing material server-only.
ENABLE_VIDEO=true
ENABLE_VIDEO_TRANSCODING=false
VIDEO_REQUIRE_APP_CHECK=false
VIDEO_INPUT_BUCKET=al-ai-chat.firebasestorage.app
VIDEO_OUTPUT_BUCKET=
VIDEO_ARCHIVE_BUCKET=
VIDEO_TRANSCODER_LOCATION=us-central1
VIDEO_CDN_BASE_URL=
VIDEO_CDN_KEY_NAME=
VIDEO_CDN_SIGNING_KEY=
VIDEO_COOKIE_DOMAIN=
VIDEO_UPLOAD_MAX_MB=10240
VIDEO_COOKIE_TTL_SECONDS=300
VIDEO_SESSION_TTL_SECONDS=600
ENABLE_4K=false
