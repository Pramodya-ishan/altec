# Google Cloud Vertex AI & Storage Settings
GOOGLE_CLOUD_PROJECT=al-ai-chat
GOOGLE_CLOUD_LOCATION=global
GOOGLE_APPLICATION_CREDENTIALS_JSON=

# Gemini Models
GEMINI_FAST_MODEL=gemini-2.0-flash
GEMINI_DEFAULT_MODEL=gemini-2.5-flash
GEMINI_PRO_MODEL=gemini-2.5-pro
GEMINI_IMAGE_MODEL=imagen-3.0-generate-001

# Legacy image model env names are still accepted:
# NANO_BANANA_MODEL=
# NANO_BANANA_PRO_MODEL=

# RAG & Optional Features
ENABLE_GOOGLE_SEARCH_GROUNDING=true
ENABLE_NOTEBOOKLM_ENTERPRISE=false

# System Tuning
ENABLE_FIRESTORE_CLIENT_WRITES=false
ENABLE_SERVER_FIRESTORE_BACKUP=false
AL_EXAM_START_DATE=2026-08-11
APP_TIME_ZONE=Asia/Colombo
