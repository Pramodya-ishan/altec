# CLORA X / ALTEC — COMPLETE ENVIRONMENT TEMPLATE
# Copy to .env for local development. In Vercel, add each value through
# Project Settings -> Environment Variables for Production, Preview, and Development.
# Never commit a populated .env file. Never put server secrets in a VITE_* variable.

# -----------------------------------------------------------------------------
# Runtime and deployment
# -----------------------------------------------------------------------------
# Vercel sets NODE_ENV for builds/functions. Do not add NODE_ENV manually in
# Vercel Environment Variables; doing so can make npm omit build-time types.
PORT=3000
APP_DEPLOY_TARGET=vercel
APP_TIME_ZONE=Asia/Colombo
AL_EXAM_START_DATE=2026-08-11
VITE_APP_VERSION=1.0.0

# Vercel supplies VERCEL, VERCEL_ENV, VERCEL_URL and
# VERCEL_PROJECT_PRODUCTION_URL automatically. Do not create them manually.

# Browser/API routing. Empty means same-origin /api on Vercel.
VITE_API_BASE_URL=
VITE_BACKEND_DIRECT_URL=

# Production origins are comma-separated; never use * in production.
ALLOWED_ORIGINS=https://tecal.vercel.app,https://tecal-pramodya-ishans-projects.vercel.app,https://tecal-git-main-pramodya-ishans-projects.vercel.app

# Production safety controls
DEV_BYPASS_AUTH=false
ENABLE_MOCK_ROUTES=false
ENABLE_MODEL_TEST_ROUTE=false
DEBUG_API=false
DISABLE_HMR=false
MAX_BODY_LIMIT_MB=2
RATE_LIMIT_IP_WINDOW_MS=60000
RATE_LIMIT_IP_MAX=100
RATE_LIMIT_UID_WINDOW_MS=60000
RATE_LIMIT_UID_MAX=100

# -----------------------------------------------------------------------------
# Firebase / Google Cloud server configuration
# -----------------------------------------------------------------------------
GOOGLE_CLOUD_PROJECT=al-ai-chat
GOOGLE_CLOUD_LOCATION=global
FIREBASE_PROJECT_ID=al-ai-chat
FIRESTORE_DATABASE_ID=ai-studio-c097068e-a4a9-4ea3-9b00-0b3195093c42
FIREBASE_STORAGE_BUCKET=al-ai-chat.firebasestorage.app

# Recommended server credential for Vercel. Paste the complete service-account
# JSON as one encrypted Vercel value. It must start with { and end with }.
# Never enter placeholder text such as PASTE_SERVICE_ACCOUNT_JSON_HERE.
# Do not add it to any VITE_* variable.
GOOGLE_APPLICATION_CREDENTIALS_JSON=

# Optional split credential mode. Leave blank when using the JSON value above.
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Local file-based ADC only. Do not set this path on Vercel.
GOOGLE_APPLICATION_CREDENTIALS=

# Server encryption key for encrypted application data (32+ random bytes).
ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# Firebase browser configuration (public project identifiers)
# -----------------------------------------------------------------------------
VITE_FIREBASE_API_KEY=AIzaSyCUmDoqn4Ta8Xtiw98jBoIhSaygUhRqacU
# Production uses the app domain so redirect auth can return to the same
# origin through the /__/auth proxy in vercel.json.
VITE_FIREBASE_AUTH_DOMAIN=al-ai-chat.firebaseapp.com
# Keep false unless a custom Firebase Hosting auth domain is fully configured.
VITE_FIREBASE_USE_CUSTOM_AUTH_DOMAIN=false
VITE_FIREBASE_PROJECT_ID=al-ai-chat
VITE_FIREBASE_STORAGE_BUCKET=al-ai-chat.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=807408268472
VITE_FIREBASE_APP_ID=1:807408268472:web:98f3f746399558968bb04d
VITE_FIRESTORE_DATABASE_ID=ai-studio-c097068e-a4a9-4ea3-9b00-0b3195093c42

# Firebase App Check reCAPTCHA v3 site key. This is a browser site key, not the
# reCAPTCHA secret. Set before changing VIDEO_REQUIRE_APP_CHECK to true.
VITE_FIREBASE_APP_CHECK_SITE_KEY=

# -----------------------------------------------------------------------------
# Gemini / Vertex AI
# -----------------------------------------------------------------------------
# true = Vertex AI with the Google service account; false = Gemini API key mode.
GEMINI_USE_VERTEX=true
GEMINI_API_KEY=

GEMINI_DEFAULT_MODEL=gemini-3.5-flash
GEMINI_NORMAL_MODEL=gemini-3.5-flash
GEMINI_FAST_MODEL=gemini-3.5-flash
GEMINI_LITE_MODEL=gemini-3.5-flash
GEMINI_PRO_MODEL=gemini-3.1-pro-preview
GEMINI_FINAL_MODEL=gemini-3.1-pro-preview
GEMINI_FINAL_FALLBACK=gemini-2.5-pro
GEMINI_PDF_QA_MODEL=gemini-3.5-flash
GEMINI_PDF_QA_FALLBACK=gemini-2.5-flash
GEMINI_SEARCH_MODEL=gemini-3.5-flash
GEMINI_URL_CONTEXT_MODEL=gemini-3.5-flash
GEMINI_VISION_MODEL=gemini-3.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
GEMINI_IMAGE_PRO_MODEL=gemini-3-pro-image-preview
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview
NANO_BANANA_MODEL=gemini-2.5-flash-image
NANO_BANANA_PRO_MODEL=gemini-3-pro-image-preview

# AI workflow switches
ENABLE_LLM_ROUTER=false
ENABLE_DIRECT_PDF_QA=true
ENABLE_MEMORY_EXTRACTION=false
ENABLE_AI_SUGGESTIONS=true
ENABLE_IMAGE_GENERATION=false
ENABLE_AUTO_WEB_SEARCH=false
ENABLE_VISUAL_BLOCKS=true
ENABLE_RAG_UPLOAD=true
ENABLE_FIRESTORE_RAG=true
ENABLE_SERVER_CHAT_SAVE=true
ENABLE_URL_CONTEXT=true
ENABLE_GOOGLE_SEARCH_GROUNDING=true
ENABLE_AI_SELF_TEST=true

# Optional verified SFT syllabus PDF in Firebase Storage. Keep its token URL in
# Vercel encrypted environment variables, never in source control.
SFT_SYLLABUS_PDF_URL=
# Preferred for Vertex AI: token-free object path inside FIREBASE_STORAGE_BUCKET.
# Example: users/<uid>/past_papers/SFT/past_paper/Syllabus/<id>/sALSyl_SFT_1_.pdf
SFT_SYLLABUS_STORAGE_PATH=

# -----------------------------------------------------------------------------
# Realtime voice (Gemini Live by default)
# -----------------------------------------------------------------------------
ENABLE_REALTIME_VOICE=true
ENABLE_GEMINI_LIVE=true
REALTIME_PROVIDER=gemini_live

# Optional OpenAI realtime provider. Leave blank while using Gemini Live.
OPENAI_API_KEY=
OPENAI_REALTIME_MODEL=gpt-realtime
OPENAI_REALTIME_VOICE=alloy

# -----------------------------------------------------------------------------
# OCR and document processing
# -----------------------------------------------------------------------------
OCR_ENABLED=false
ENABLE_AUTO_OCR=false
ENABLE_CLOUD_VISION_OCR=false
OCR_PROVIDER=cloud_vision
OCR_INPUT_BUCKET=al-ai-chat-ocr-input
OCR_OUTPUT_BUCKET=al-ai-chat-ocr-output
VISION_OCR_INPUT_BUCKET=al-ai-chat-ocr-input
VISION_OCR_OUTPUT_BUCKET=al-ai-chat-ocr-output

# Confirmed historical per-user limits
DAILY_DIRECT_PDF_QA_LIMIT_PER_USER=30
DAILY_PRO_REQUEST_LIMIT_PER_USER=30
DAILY_OCR_LIMIT_PER_USER=5
DAILY_WEB_SEARCH_LIMIT_PER_USER=20

# -----------------------------------------------------------------------------
# Text-to-speech
# -----------------------------------------------------------------------------
ENABLE_TTS=false
ENABLE_TTS_CACHE=true
ENABLE_TTS_LIMITS=true
TTS_PROVIDER=google
TTS_DEFAULT_LANGUAGE=si-LK
TTS_MAX_CHARS=5000

# Optional ElevenLabs provider
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# -----------------------------------------------------------------------------
# Secure lesson videos
# -----------------------------------------------------------------------------
ENABLE_VIDEO=true

# Keep false until the private output bucket, Transcoder IAM and Cloud CDN are
# fully configured. With false, uploads remain private and are not publishable.
ENABLE_VIDEO_TRANSCODING=false
# Short-lived authenticated original-file fallback. Keep true unless signed
# HLS/CDN transcoding is fully configured.
# Authenticated, short-lived direct playback fallback used when Transcoder is
# unavailable. Keep true unless every upload is guaranteed to produce HLS.
VIDEO_ALLOW_DIRECT_PLAYBACK=true

# Enable only after VITE_FIREBASE_APP_CHECK_SITE_KEY is active in production.
VIDEO_REQUIRE_APP_CHECK=false

VIDEO_INPUT_BUCKET=al-ai-chat.firebasestorage.app
VIDEO_OUTPUT_BUCKET=
VIDEO_ARCHIVE_BUCKET=
VIDEO_TRANSCODER_LOCATION=us-central1

# Example: https://video.example.com (no trailing slash)
VIDEO_CDN_BASE_URL=
VIDEO_CDN_KEY_NAME=
VIDEO_CDN_SIGNING_KEY=

# Example when app.example.com and video.example.com share a parent domain:
# VIDEO_COOKIE_DOMAIN=.example.com
VIDEO_COOKIE_DOMAIN=

VIDEO_UPLOAD_MAX_MB=10240
VIDEO_COOKIE_TTL_SECONDS=300
VIDEO_SESSION_TTL_SECONDS=600
ENABLE_4K=false

# -----------------------------------------------------------------------------
# Application ownership / content metadata
# -----------------------------------------------------------------------------
# Verified Firebase users listed here receive content-management roles. This is
# server-only and may contain multiple comma-separated email addresses.
ADMIN_EMAILS=
# Recommended stable authorization boundary. Copy the Firebase Auth UID(s),
# comma-separated. UID matching does not depend on Google email claim timing.
ADMIN_UIDS=
SYLLABUS_OWNER_EMAIL=
VITE_SYLLABUS_OWNER_EMAIL=

# Vercel project build configuration (set in vercel.json, not as env vars):
# installCommand = npm ci --include=dev
# buildCommand   = npm run build:vercel
# outputDirectory = dist
