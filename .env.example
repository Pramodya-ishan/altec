# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY=
GEMINI_ANALYSIS_MODEL=gemini-3.5-flash
GEMINI_FINAL_MODEL=gemini-3.1-pro-preview
GEMINI_FAST_FALLBACK_MODEL=gemini-3.1-flash-lite
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image

AL_EXAM_START_DATE=2026-08-01
APP_TIME_ZONE=Asia/Colombo

APP_URL=
VITE_GOOGLE_CLIENT_ID=

# Development-only encrypted-file fallback.
# Production must use Firestore.
ENCRYPTION_KEY=
ENABLE_LOCAL_FILE_DB=false

# Disable external AI fallbacks for academic data.
ENABLE_EXTERNAL_AI_FALLBACK=false
