rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return signedIn() && (
        request.auth.token.admin == true ||
        request.auth.token.role == "admin" ||
        (request.auth.token.roles != null && (
          "admin" in request.auth.token.roles ||
          "ops" in request.auth.token.roles ||
          "content_editor" in request.auth.token.roles
        ))
      );
    }

    function validUpload() {
      return request.resource.size < 50 * 1024 * 1024
        && (
          request.resource.contentType.matches('application/pdf') ||
          request.resource.contentType.matches('image/.*') ||
          request.resource.contentType.matches('audio/.*') ||
          request.resource.contentType.matches('text/.*') ||
          request.resource.contentType == 'application/json' ||
          request.resource.contentType.matches('application/vnd.openxmlformats-officedocument.*') ||
          request.resource.contentType.matches('application/octet-stream') ||
          request.resource.contentType == null ||
          request.resource.contentType == ""
        );
    }

    match /rag_uploads/{uid}/{allPaths=**} {
      allow read, delete: if isOwner(uid) || isAdmin();
      allow write: if (isOwner(uid) || isAdmin()) && validUpload();
    }

    match /users/{uid}/past_papers/{allPaths=**} {
      allow read: if signedIn();
      allow delete: if isOwner(uid) || isAdmin();
      allow write: if (isOwner(uid) || isAdmin()) && validUpload();
    }

    match /users/{uid}/syllabus/{allPaths=**} {
      allow read: if signedIn();
      allow delete: if isOwner(uid) || isAdmin();
      allow write: if (isOwner(uid) || isAdmin()) && validUpload();
    }

    match /users/{uid}/paper_structure/{allPaths=**} {
      allow read, delete: if isOwner(uid) || isAdmin();
      allow write: if (isOwner(uid) || isAdmin()) && validUpload();
    }

    match /users/{uid}/images/{allPaths=**} {
      allow read, delete: if isOwner(uid) || isAdmin();
      allow write: if (isOwner(uid) || isAdmin()) && validUpload();
    }

    match /users/{uid}/knowledge/{allPaths=**} {
      allow read, delete: if isOwner(uid) || isAdmin();
      allow write: if (isOwner(uid) || isAdmin()) && validUpload();
    }

    match /users/{uid}/voice/{allPaths=**} {
      allow read, delete: if isOwner(uid) || isAdmin();
      allow write: if (isOwner(uid) || isAdmin()) && validUpload();
    }

    match /users/{uid}/{allPaths=**} {
      allow read, delete: if isOwner(uid) || isAdmin();
      allow write: if (isOwner(uid) || isAdmin()) && validUpload();
    }

    match /files/{allPaths=**} {
      allow read, write: if isAdmin();
    }
  }
}
