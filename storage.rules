rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null && request.auth.token.firebase.sign_in_provider != "anonymous";
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function hasRole(role) {
      return signedIn() && (
        request.auth.token.role == role ||
        (request.auth.token.roles != null && role in request.auth.token.roles)
      );
    }

    function canManageLessonResources() {
      return signedIn() && (
        request.auth.token.admin == true ||
        hasRole("admin") || hasRole("content_editor") || hasRole("teacher") || hasRole("ops")
      );
    }

    function isAllowedImage() {
      return request.resource.contentType in ["image/png", "image/jpeg", "image/webp"];
    }

    function isAllowedPersonalAttachment() {
      return (request.resource.contentType == "application/pdf" && request.resource.size <= 25 * 1024 * 1024)
        || (isAllowedImage() && request.resource.size <= 10 * 1024 * 1024);
    }

    function isAllowedSharedResource() {
      return (request.resource.contentType == "application/pdf" && request.resource.size <= 50 * 1024 * 1024)
        || (isAllowedImage() && request.resource.size <= 20 * 1024 * 1024);
    }

    match /rag_uploads/{uid}/{sourceId}/{fileName} {
      allow read: if isOwner(uid);
      allow create, update: if isOwner(uid) && isAllowedPersonalAttachment();
      allow delete: if isOwner(uid);
    }

    match /users/{uid}/images/{allPaths=**} {
      allow read: if isOwner(uid);
      allow create, update: if isOwner(uid) && isAllowedPersonalAttachment();
      allow delete: if isOwner(uid);
    }

    match /users/{uid}/attachments/{allPaths=**} {
      allow read: if isOwner(uid);
      allow create, update: if isOwner(uid) && isAllowedPersonalAttachment();
      allow delete: if isOwner(uid);
    }

    match /users/{uid}/paper_structure/{allPaths=**} {
      allow read: if signedIn();
      allow create, update: if isOwner(uid) && canManageLessonResources() && isAllowedSharedResource();
      allow delete: if isOwner(uid) && canManageLessonResources();
    }

    match /users/{uid}/past_papers/{allPaths=**} {
      allow read: if signedIn();
      allow create, update: if isOwner(uid) && canManageLessonResources() && isAllowedSharedResource();
      allow delete: if isOwner(uid) && canManageLessonResources();
    }

    match /users/{uid}/syllabus/{allPaths=**} {
      allow read: if signedIn();
      allow create, update: if isOwner(uid) && canManageLessonResources() && isAllowedSharedResource();
      allow delete: if isOwner(uid) && canManageLessonResources();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
