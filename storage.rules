rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null && request.auth.token.firebase.sign_in_provider != "anonymous";
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function hasRole(role) {
      return signedIn() && (
        request.auth.token.role == role ||
        (request.auth.token.roles != null && role in request.auth.token.roles)
      );
    }

    function canManageContent() {
      return signedIn() && (
        request.auth.token.admin == true ||
        hasRole("admin") || hasRole("content_editor") || hasRole("teacher") || hasRole("ops")
      );
    }

    function isAllowedImage() {
      return request.resource.contentType in ["image/png", "image/jpeg", "image/webp"];
    }

    function isAllowedPersonalAttachment() {
      return (request.resource.contentType == "application/pdf" && request.resource.size <= 25 * 1024 * 1024)
        || (isAllowedImage() && request.resource.size <= 10 * 1024 * 1024);
    }

    function isAllowedSharedDocument() {
      return (request.resource.contentType == "application/pdf" && request.resource.size <= 50 * 1024 * 1024)
        || (isAllowedImage() && request.resource.size <= 20 * 1024 * 1024);
    }

    match /rag_uploads/{uid}/{sourceId}/{fileName} {
      allow read: if isOwner(uid);
      allow create, update: if isOwner(uid) && isAllowedPersonalAttachment();
      allow delete: if isOwner(uid);
    }

    match /users/{uid}/images/{allPaths=**} {
      allow read: if isOwner(uid);
      allow create, update: if isOwner(uid) && isAllowedPersonalAttachment();
      allow delete: if isOwner(uid);
    }

    match /users/{uid}/attachments/{allPaths=**} {
      allow read: if isOwner(uid);
      allow create, update: if isOwner(uid) && isAllowedPersonalAttachment();
      allow delete: if isOwner(uid);
    }

    // Shared files are never read directly with the Firebase client SDK. The
    // authenticated API checks publication/audience metadata and returns a
    // short-lived signed URL or secure stream.
    match /shared_resources/{resourceId}/{allPaths=**} {
      allow read: if false;
      allow create, update: if canManageContent() && isAllowedSharedDocument();
      allow delete: if canManageContent();
    }

    // Legacy paths remain writable only by a content manager who owns the
    // prefix. Direct reads are disabled to avoid bypassing publication checks.
    match /users/{uid}/{scope}/{allPaths=**} {
      allow read: if false;
      allow create, update: if isOwner(uid)
        && canManageContent()
        && scope in ["paper_structure", "past_papers", "syllabus"]
        && isAllowedSharedDocument();
      allow delete: if isOwner(uid)
        && canManageContent()
        && scope in ["paper_structure", "past_papers", "syllabus"];
    }

    match /videos/{allPaths=**} {
      allow read, write: if false;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
